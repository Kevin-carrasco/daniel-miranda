@incollection{miranda_measurement_2018,
  title = {Measurement {{Model}} and {{Invariance Testing}} of {{Scales Measuring Egalitarian Values}} in {{ICCS}} 2009},
  booktitle = {Teaching {{Tolerance}} in a {{Globalized World}}},
  author = {Miranda, Daniel and Castillo, Juan Carlos},
